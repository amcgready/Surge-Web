    "zurg": {
      "name": "zurg",
      "desc": "Real-Debrid filesystem mount (rclone bundled)",
      "category": "debrid",
      "repo": "https://github.com/debridmediamanager/zurg-testing",
      "compose": {
        "files": {
          "rcloneConf": {
            "hostPath": "configRoot/<service>/rclone.conf",
            "content": "[zurg]\ntype = webdav\nurl = http://zurg:9999/dav\nvendor = other\npacer_min_sleep = 0\n"
          },
          "configYml": {
            "hostPath": "configRoot/<service>/config.yml",
            "content": "zurg: v1\ntoken: ${rdApiToken}\n"
          },
          "plexUpdateSh": {
            "hostPath": "configRoot/<service>/scripts/plex_update.sh",
            "content": {
              "fromUpstream": "https://raw.githubusercontent.com/debridmediamanager/zurg-testing/main/scripts/plex_update.sh",
              "fallback": "#!/bin/bash\n\n# PLEX PARTIAL SCAN script or PLEX UPDATE script\n# When zurg detects changes, it can trigger this script IF your config.yml contains\n# on_library_update: sh plex_update.sh \"$@\"\n\n# docker compose exec zurg apk add libxml2-utils\n# sudo apt install libxml2-utils\n\nplex_url=\"http://<url>\" # If you're using zurg inside a Docker container, by default it is 172.17.0.1:32400\ntoken=\"<token>\" # open Plex in a browser, open dev console and copy-paste this: window.localStorage.getItem(\"myPlexAccessToken\")\nzurg_mount=\"/mnt/zurg\" # replace with your zurg mount path, ensure this is what Plex sees\n\n# Get the list of section IDs\nsection_ids=$(curl -sLX GET \"$plex_url/library/sections\" -H \"X-Plex-Token: $token\" | xmllint --xpath \"//Directory/@key\" - | grep -o 'key=\"[^\"]*\"' | awk -F'\"' '{print $2}')\n\nfor arg in \"$@\"\ndo\n    parsed_arg=\"${arg//\\\\}\"\n    echo $parsed_arg\n    modified_arg=\"$zurg_mount/$parsed_arg\"\n    echo \"Detected update on: $arg\"\n    echo \"Absolute path: $modified_arg\"\n\n    for section_id in $section_ids\n    do\n        echo \"Section ID: $section_id\"\n\n        curl -G -H \"X-Plex-Token: $token\" --data-urlencode \"path=$modified_arg\" $plex_url/library/sections/$section_id/refresh\n    done\ndone\n\necho \"All updated sections refreshed\"\n\n# credits to godver3, wasabipls"
            },
            "mode": 493
          }
        },
        "services": {
          "zurg": {
            "image": "ghcr.io/debridmediamanager/zurg-testing:latest",
            "networkMode": "bridge",
            "ports": [
              "9999:9999"
            ],
            "mounts": [
              {
                "src": "configRoot/<service>/scripts/plex_update.sh",
                "dst": "/app/plex_update.sh"
              },
              {
                "src": "configRoot/<service>/config.yml",
                "dst": "/app/config.yml"
              },
              {
                "src": "configRoot/<service>/data",
                "dst": "/app/data"
              },
              {
                "src": "mediaRoot/media",
                "dst": "/media"
              }
            ]
          },
          "rclone": {
            "image": "rclone/rclone:latest",
            "networkMode": "bridge",
            "capAdd": [
              "SYS_ADMIN"
            ],
            "securityOpt": [
              "apparmor:unconfined"
            ],
            "devices": [
              "/dev/fuse:/dev/fuse:rwm"
            ],
            "command": "mount zurg: /data --allow-other --allow-non-empty --dir-cache-time 10s --vfs-cache-mode full --vfs-cache-max-size 50G --vfs-cache-max-age 1h --buffer-size 64M --vfs-read-ahead 256M",
            "mounts": [
              {
                "src": "mediaRoot/media/Intake/zurg",
                "dst": "/data",
                "options": "rshared"
              },
              {
                "src": "configRoot/<service>/rclone.conf",
                "dst": "/config/rclone/rclone.conf"
              },
              {
                "src": "mediaRoot/<service>/rclone-cache",
                "dst": "/cache"
              }
            ],
            "dependsOn": {
              "zurg": {}
            }
          }
        }
      }
    },
