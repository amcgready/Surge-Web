        "env": {
          "EMBY_PublishedServerUrl": {
            "fromConfig": "embySettings.EMBY_PublishedServerUrl",
            "defaultValue": ""
          },
          "UID": "99",
          "GID": "100"
        },
        "mounts": [
          {
            "src": "configRoot/<service>",
            "dst": "/config"
          },
          {
            "src": "mediaRoot/media",
            "dst": "/media"
          },
          {
            "src": "mediaRoot/<service>/transcoding-temp",
            "dst": "/transcoding-temp"
          }
        ],
        "fetchScript": {
          "path": "scripts/fetch-emby-secrets.py",
          "env": {
            "EMBY_PASSWORD": {
              "fromSecret": "adminPassword"
            }
          }
        }
      }
    }
  }
}