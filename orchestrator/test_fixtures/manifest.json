            "PLEX_URL": {
              "whenMediaServer": "plex",
              "value": "http://localhost:32400"
            },
            "PLEX_TOKEN": {
              "whenMediaServer": "plex",
              "fromService": "plex",
              "field": "plexToken"
            },
            "TMDB_API_KEY": {
              "fromConfig": "tmdbApiKey",
              "defaultValue": ""
            },
            "FANART_API_KEY": {
              "fromConfig": "fanartApiKey",
              "defaultValue": ""
            },
            "TVDB_API_KEY": {
              "fromConfig": "tvdbApiKey",
              "defaultValue": ""
            }
          }
        }
      }
    },
    "prowlarr": {
      "name": "Prowlarr",
      "desc": "Indexer manager",
      "category": "indexers",
      "repo": "https://github.com/prowlarr/prowlarr",
      "compose": {
        "image": "lscr.io/linuxserver/prowlarr:latest",
        "ports": [
          "9696:9696"
