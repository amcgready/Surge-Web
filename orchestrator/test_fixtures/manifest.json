            },
            "SONARR_API_KEY": {
              "whenService": "sonarr",
              "fromServiceSecret": "sonarr",
              "secret": "apiKey"
            },
            "RADARR_URL": {
              "whenService": "radarr",
              "value": "http://localhost:7878"
