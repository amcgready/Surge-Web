    "nzbdav": {
      "name": "NzbDAV",
      "desc": "WebDAV layer for usenet content",
      "category": "downloads",
      "repo": "https://github.com/nzbdav-dev/nzbdav",
      "compose": {
        "secrets": {
          "webdavPassword": {
            "generate": "random",
            "length": 32
          },
          "frontendBackendApiKey": {
            "generate": "random",
            "length": 64
          }
        },
        "services": {
          "nzbdav": {
            "image": "nzbdav/nzbdav:alpha",
            "networkMode": "bridge",
            "ports": [
              "3000:3000"
            ],
            "mounts": [
              {
                "src": "configRoot/<service>",
                "dst": "/config"
              }
            ],
            "env": {
              "FRONTEND_BACKEND_API_KEY": {
                "fromSecret": "frontendBackendApiKey"
              }
            }
          },
          "rclone": {
            "image": "rclone/rclone:latest",
            "networkMode": "bridge",
            "capAdd": [
              "SYS_ADMIN"
            ],
            "securityOpt": [
              "apparmor:unconfined"
            ],
            "devices": [
              "/dev/fuse:/dev/fuse:rwm"
            ],
            "command": "mount nzbdav: /nzbdav --allow-other --allow-non-empty --dir-cache-time 10s --vfs-cache-mode full --vfs-cache-max-size 50G --vfs-cache-max-age 1h --buffer-size 64M --vfs-read-ahead 256M",
            "mounts": [
              {
                "src": "mediaRoot/media/Intake/nzbdav",
                "dst": "/nzbdav",
                "options": "rshared"
              },
              {
                "src": "configRoot/<service>/rclone.conf",
                "dst": "/config/rclone/rclone.conf"
              },
              {
                "src": "mediaRoot/<service>/rclone-cache",
                "dst": "/cache"
              }
            ],
            "dependsOn": {
              "nzbdav": {}
            }
          }
        },
        "postDeployScript": {
          "path": "scripts/configure-nzbdav.py",
          "blocks": [
            "rclone"
          ],
          "env": {
            "NZBDAV_PASSWORD": {
              "fromSecret": "webdavPassword"
            },
            "NZBDAV_API_KEY": {
              "fromSecret": "frontendBackendApiKey"
            },
            "RCLONE_CONF_PATH": "configRoot/<service>/rclone.conf"
          }
        }
      }
    },
    "posterizarr": {
      "name": "Posterizarr",
      "desc": "Poster automation",
